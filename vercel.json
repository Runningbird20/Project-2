{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python manage.py collectstatic --noinput",
  "functions": {
    "api/wsgi.py": {
      "runtime": "python3.13",
      "includeFiles": [
        "staticfiles/**",
        "db.sqlite3"
      ],
      "excludeFiles": [
        ".git/**",
        "**/__pycache__/**",
        "media/**",
        "resumes/**",
        "**/tests*.py"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/wsgi.py"
    }
  ]
}
  
  
